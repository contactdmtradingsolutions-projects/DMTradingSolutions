{
  "entities": {
    "PageContent": {
      "title": "Page Content",
      "description": "Content for a specific page or section of the website.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The main title of the page or section."
        },
        "subtitle": {
          "type": "string",
          "description": "The subtitle or description."
        },
        "description": {
          "type": "string",
          "description": "The main description text."
        },
        "paragraph1": {
          "type": "string",
          "description": "First paragraph of text."
        },
        "paragraph2": {
          "type": "string",
          "description": "Second paragraph of text."
        },
        "image": {
          "type": "string",
          "description": "A single image URL."
        },
        "heroImages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of hero image URLs."
        },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "content": { "type": "string" },
              "image": { "type": "string" }
            }
          },
          "description": "Content sections."
        }
      }
    },
    "User": {
      "title": "User",
      "description": "Admin user profile.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": ["admin"]
        }
      },
      "required": ["email", "role"]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "A blog post article.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "author": { "type": "string" },
        "excerpt": { "type": "string" },
        "image": { "type": "string" },
        "content": { "type": "string" },
        "link": { "type": "string" }
      },
      "required": ["title", "date", "author", "excerpt", "image", "content"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global website settings like colors.",
      "type": "object",
      "properties": {
        "corporateNavy": { "type": "string" },
        "corporateBlue": { "type": "string" },
        "corporateGold": { "type": "string" },
        "corporateLight": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/settings/{settingId}": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "Stores global website settings."
    },
    "/content/{pageId}": {
      "schema": { "$ref": "#/entities/PageContent" },
      "description": "Stores content for different pages (e.g., home, about, services)."
    },
    "/blogPosts/{postId}": {
      "schema": { "$ref": "#/entities/BlogPost" },
      "description": "Stores blog posts."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles."
    }
  }
}
